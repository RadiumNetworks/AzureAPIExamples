{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logicAppName": {
      "value": "credential-expiry-monitor-logicApp"
    },
    "logAnalyticsWorkspaceId": {
      "value": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/myResourceGroup/providers/Microsoft.OperationalInsights/workspaces/myWorkspace"
    },
    "logAnalyticsWorkspaceKey": {
      "value": "<your-workspace-shared-key>"
    },
    "logAnalyticsCustomerId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "expiryThresholdDays": {
      "value": 30
    },
    "customLogTableName": {
      "value": "AppCredentialExpiry"
    },
    "recurrenceHour": {
      "value": 7
    }
  }
}